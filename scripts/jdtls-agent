#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
JAR="$ROOT/target/jdtls-agent-0.1.0-all.jar"

if [[ ! -f "$JAR" ]]; then
  echo "Missing $JAR; run: JAVA_HOME=/opt/homebrew/opt/openjdk@21 mvn -q -DskipTests package" >&2
  exit 1
fi

if [[ -n "${JDTLS_AGENT_JAVA:-}" ]]; then
  JAVA_BIN="$JDTLS_AGENT_JAVA"
elif [[ -x /opt/homebrew/opt/openjdk@21/bin/java ]]; then
  JAVA_BIN=/opt/homebrew/opt/openjdk@21/bin/java
elif [[ -n "${JAVA_HOME:-}" && -x "$JAVA_HOME/bin/java" ]]; then
  JAVA_BIN="$JAVA_HOME/bin/java"
else
  JAVA_BIN=java
fi

exec "$JAVA_BIN" -jar "$JAR" client "$@"
